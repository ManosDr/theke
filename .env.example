# --- Postgres ---
POSTGRES_USER=theke
POSTGRES_PASSWORD=changeme
POSTGRES_DB=theke
DATABASE_URL=postgresql+psycopg://theke:changeme@postgres:5432/theke

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=changeme-dev-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Set both to bootstrap the one platform super_admin account on backend
# startup. There is no signup flow for this role - it only exists via this
# env-var bootstrap. Leave blank to skip (no super admin created).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Creates 5 fixed demo accounts (super admin, construction admin/member,
# municipality admin/member; password "demo1234") on startup for the login
# page's demo-login buttons. Leave false for any real deployment.
SEED_DEMO_DATA=true

# --- OpenAI ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o

# --- Frontend ---
# Baked into the client bundle at build time (see frontend/Dockerfile.prod),
# not read at container start - changing this requires a rebuild, not just
# a container restart. In production behind infra/nginx.conf, this should
# be the relative path "/api" (nginx proxies /api/* to the backend on the
# same origin) rather than a backend hostname/port the browser can't reach.
NEXT_PUBLIC_API_URL=http://localhost:8000
