# --- Environment ---
# "development" or "production". development (the value to use for local
# work - see README's Getting Started) keeps /docs and /redoc enabled and
# other dev-only conveniences on; production disables them. Shown here as
# production since this file is the reference for a real deployment - flip
# to development in your own local .env.
ENVIRONMENT=production

# Comma-separated list of frontend origins allowed to call this API
# (CORS). Must be updated to the real production domain before deployment,
# e.g. CORS_ORIGINS=https://yourdomain.com - the placeholder below will
# not match any real browser origin. Local dev should use
# CORS_ORIGINS=http://localhost:3000 (config.py's own default if this
# var is unset/absent, so local dev is unaffected either way).
CORS_ORIGINS=https://yourdomain.com

# --- Postgres ---
POSTGRES_USER=theke
POSTGRES_PASSWORD=changeme
POSTGRES_DB=theke
DATABASE_URL=postgresql+psycopg://theke:changeme@postgres:5432/theke

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=changeme-dev-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Set both to bootstrap the one platform super_admin account on backend
# startup. There is no signup flow for this role - it only exists via this
# env-var bootstrap. Leave blank to skip (no super admin created).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Creates 5 fixed demo accounts (super admin, construction admin/member,
# municipality admin/member; password "demo1234") on startup for the login
# page's demo-login buttons. Must be false in production. Set to true in
# your own local .env for local dev (see README's Getting Started).
SEED_DEMO_DATA=false

# --- OpenAI ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o

# --- Email (Resend) ---
# Password-reset links are built against this - the frontend's own origin,
# not this API's. In production this is the real domain, e.g.
# https://yourdomain.com.
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
# Must be explicitly true in production. false (the default) means
# password-reset emails are never sent - the link is logged instead (see
# app/routers/auth.py's forgot-password endpoint). Never leave true in an
# environment without a real RESEND_API_KEY.
EMAIL_ENABLED=false

# --- Frontend ---
# Baked into the client bundle at build time (see frontend/Dockerfile.prod),
# not read at container start - changing this requires a rebuild, not just
# a container restart. In production behind infra/nginx.conf, this should
# be the relative path "/api" (nginx proxies /api/* to the backend on the
# same origin) rather than a backend hostname/port the browser can't reach.
NEXT_PUBLIC_API_URL=http://localhost:8000
